# ─────────────────────────────────────────────────────────────
#  VOYAGO – premenné prostredia. Skopíruj do .env.local (lokál)
#  a nastav rovnaké aj na Verceli (Project → Settings → Environment Variables).
# ─────────────────────────────────────────────────────────────

# ── Supabase (objednávky, sledovanie stavu, chat, úložisko) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # len server, NIKDY neexponovať klientovi

# ── Stripe (platby + webhook) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=              # z webhook endpointu /api/stripe/webhook

# ── Resend (e-maily: potvrdenia, zmena stavu, chat notifikácie) ──
RESEND_API_KEY=
EMAIL_FROM=Voyago <noreply@tvojadomena.sk>
ADMIN_NOTIFY_EMAIL=                # kam chodia notifikácie z chatu (prázdne = použije sa site.email)

# ── Cloudflare Turnstile (captcha na formulároch) ──
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Plausible (cookieless analytika; nepovinné) ──
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

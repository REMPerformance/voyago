# Skopíruj do .env.local a doplň reálne kľúče (zatiaľ nie sú potrebné na spustenie).

# Stripe (pridáme pri napojení platby)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase / databáza (pridáme pri ukladaní objednávok)
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
